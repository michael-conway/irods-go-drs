# irods-provider based on Ubuntu 24.04 (Noble) for iRODS 5.x
FROM --platform=linux/amd64 ubuntu:24.04
ARG DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV IRODS_VERSION=5.0.3

# install prerequisites and add iRODS apt repo
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      wget gnupg ca-certificates lsb-release netcat-openbsd iproute2 procps tzdata python3-pip python3-setuptools python3-psycopg2 sudo && \
    # add iRODS apt repo & signing key (packages.irods.org)
    wget -qO - https://packages.irods.org/irods-signing-key.asc | apt-key add - && \
    echo "deb [arch=amd64] https://packages.irods.org/apt/ $(lsb_release -sc) main" \
      > /etc/apt/sources.list.d/renci-irods.list && \
    apt-get update && \
    # Install iRODS server packages (catalog DB runs externally)
    apt-get install -y --no-install-recommends \
      irods-server irods-runtime irods-database-plugin-postgres irods-icommands && \
    # cleanup
    rm -rf /var/lib/apt/lists/*

# Copy entrypoint and test setup script
COPY docker-entrypoint.sh /usr/local/sbin/docker-entrypoint.sh
COPY testsetup-consortium.sh /var/lib/irods/testsetup-consortium.sh
RUN chmod +x /usr/local/sbin/docker-entrypoint.sh && \
    mkdir -p /var/lib/irods && \
    (id -u irods >/dev/null 2>&1 || useradd -r -m -d /var/lib/irods -s /bin/bash irods) && \
    chown irods:irods /var/lib/irods/testsetup-consortium.sh

EXPOSE 1247 1248 20000-20199/tcp

VOLUME ["/var/lib/irods", "/etc/irods"]

ENTRYPOINT ["/usr/local/sbin/docker-entrypoint.sh"]
CMD ["run"]

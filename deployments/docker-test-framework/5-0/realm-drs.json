{
  "realm": "drs",
  "enabled": true,
  "displayName": "DRS",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "defaultScope": "openid profile email",
        "clientId": "${GOOGLE_OIDC_CLIENT_ID}",
        "clientSecret": "${GOOGLE_OIDC_CLIENT_SECRET}",
        "prompt": "select_account",
        "syncMode": "IMPORT"
      }
    }
  ],
  "clients": [
    {
      "clientId": "${DRS_API_CLIENT_ID}",
      "name": "DRS API Resource Server",
      "description": "Bearer-only client used by the DRS REST API as a protected resource server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${DRS_API_CLIENT_SECRET}",
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "protocolMappers": []
    }
  ]
}
